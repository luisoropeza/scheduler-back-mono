# Copy this file to .env and fill in real values for local development.
# .env is gitignored — never commit real secrets. In Render, set these under
# the service's Environment tab instead of using this file.

# --- Database (PostgreSQL) ---
DB_URL=jdbc:postgresql://localhost:5432/scheduler
DB_USERNAME=postgres
DB_PASSWORD=mysecretpassword

# --- Server ---
PORT=8080

# --- CORS ---
# Comma-separated list of allowed origins, e.g. https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=*

# --- JWT ---
# Must be at least 32 characters. Generate with:
#   [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
JWT_SECRET=change-me-in-production-minimum-32-chars!

# --- n8n integration (WhatsApp booking bot) ---
# Static API key the n8n workflow sends via the X-API-Key header. Generate with the same
# command as JWT_SECRET above.
N8N_API_KEY=change-me-n8n-key

# --- Mail (not currently wired to any notification flow, but required by spring.mail config) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@scheduler.local
MAIL_FROM_NAME=Scheduler
